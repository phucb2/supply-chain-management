# PostgreSQL
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=supplychain
POSTGRES_USER=supplychain
POSTGRES_PASSWORD=supplychain_secret

# Debezium CDC (replication user; set wal_level=logical via compose on postgres)
DEBEZIUM_DB_PASSWORD=debezium_secret

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=api

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5001
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_secret

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streaming benchmark
BENCHMARK_TOPIC=benchmark.e2e
BENCHMARK_MESSAGE_SIZE=256
BENCHMARK_CONCURRENCY=1
BENCHMARK_TARGET_MESSAGES=1000
BENCHMARK_TIMEOUT_SECONDS=120
BENCHMARK_SCENARIO=baseline
BENCHMARK_RUN_ID=

# External RabbitMQ benchmark target
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=benchmark.e2e

# External MQTT benchmark target
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=benchmark/e2e
