{
  "uid": "streaming-benchmark",
  "title": "Streaming Broker Benchmark",
  "tags": ["benchmark", "kafka", "rabbitmq", "mqtt"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(benchmark_messages_sent_total, scenario)",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "run_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(benchmark_messages_sent_total, run_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Send Throughput (msg/s) by Broker",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (broker) (rate(benchmark_messages_sent_total{scenario=~\"$scenario\",run_id=~\"$run_id\"}[2m]))",
          "legendFormat": "{{broker}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Receive Throughput (msg/s) by Broker",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (broker) (rate(benchmark_messages_received_total{scenario=~\"$scenario\",run_id=~\"$run_id\"}[2m]))",
          "legendFormat": "{{broker}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "E2E Latency p50/p95/p99 (ms)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (broker, le) (rate(benchmark_e2e_latency_milliseconds_bucket{scenario=~\"$scenario\",run_id=~\"$run_id\"}[2m])))",
          "legendFormat": "{{broker}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (broker, le) (rate(benchmark_e2e_latency_milliseconds_bucket{scenario=~\"$scenario\",run_id=~\"$run_id\"}[2m])))",
          "legendFormat": "{{broker}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (broker, le) (rate(benchmark_e2e_latency_milliseconds_bucket{scenario=~\"$scenario\",run_id=~\"$run_id\"}[2m])))",
          "legendFormat": "{{broker}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "row",
      "title": "Reliability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Delivery Success Ratio",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (broker) (increase(benchmark_messages_received_total{scenario=~\"$scenario\",run_id=~\"$run_id\"}[15m])) / clamp_min(sum by (broker) (increase(benchmark_messages_sent_total{scenario=~\"$scenario\",run_id=~\"$run_id\"}[15m])), 1)",
          "legendFormat": "{{broker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "type": "stat",
      "title": "Latest Run Duration (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by (broker) (benchmark_run_duration_seconds_seconds{scenario=~\"$scenario\",run_id=~\"$run_id\"})",
          "legendFormat": "{{broker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal"
      }
    }
  ]
}
