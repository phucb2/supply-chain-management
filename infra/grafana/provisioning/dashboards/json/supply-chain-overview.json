{
  "uid": "supply-chain-overview",
  "title": "Supply Chain Overview",
  "tags": ["supply-chain", "orders", "shipments"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "Order KPIs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Orders Received",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(orders_received_total{service_name=\"api\"})",
          "legendFormat": "received",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Orders Shipped",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(orders_shipped_total{service_name=\"stream-processor\"})",
          "legendFormat": "shipped",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Orders Delivered",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(orders_delivered_total{service_name=\"stream-processor\"})",
          "legendFormat": "delivered",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Orders Exception",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(orders_exception_total{service_name=\"stream-processor\"})",
          "legendFormat": "exception",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Avg Pipeline Duration",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(order_pipeline_duration_ms_milliseconds_sum{service_name=\"stream-processor\"}[5m])) / sum(rate(order_pipeline_duration_ms_milliseconds_count{service_name=\"stream-processor\"}[5m]))",
          "legendFormat": "avg ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "type": "row",
      "title": "Order Status Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Orders Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(orders_received_total{service_name=\"api\"}[5m]))", "legendFormat": "received", "refId": "A" },
        { "expr": "sum(rate(orders_validated_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "validated", "refId": "B" },
        { "expr": "sum(rate(orders_shipped_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "shipped", "refId": "C" },
        { "expr": "sum(rate(orders_delivered_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "delivered", "refId": "D" },
        { "expr": "sum(rate(orders_exception_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "exception", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "piechart",
      "title": "Orders by Channel",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (channel)(orders_received_total{service_name=\"api\"})", "legendFormat": "{{channel}}", "refId": "A" }
      ],
      "options": { "legend": { "placement": "right" } }
    },
    {
      "type": "table",
      "title": "Recent Exceptions",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"stream-processor\"} |= \"exception\" | json",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Shipment Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Shipments Created vs Delivered",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(shipments_created_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "created", "refId": "A" },
        { "expr": "sum(rate(shipments_delivered_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "delivered", "refId": "B" },
        { "expr": "sum(rate(shipments_exception_total{service_name=\"stream-processor\"}[5m]))", "legendFormat": "exception", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "type": "bargauge",
      "title": "Shipments by Carrier",
      "gridPos": { "h": 8, "w": 7, "x": 10, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (carrier)(shipments_created_total{service_name=\"stream-processor\"})", "legendFormat": "{{carrier}}", "refId": "A" }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "type": "gauge",
      "title": "Active Shipments",
      "gridPos": { "h": 8, "w": 7, "x": 17, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(shipments_created_total{service_name=\"stream-processor\"}) - sum(shipments_delivered_total{service_name=\"stream-processor\"}) - sum(shipments_exception_total{service_name=\"stream-processor\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "min": 0,
          "max": 200
        }
      }
    },

    {
      "type": "row",
      "title": "Logs & Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Recent Errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"api|stream-processor\"} | json | level =~ \"error|ERROR\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "type": "logs",
      "title": "All Service Logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"api|stream-processor\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },

    {
      "type": "row",
      "title": "API Infrastructure",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "API Latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Request Rate & Errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"api\"}[5m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"api\",http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    }
  ]
}
