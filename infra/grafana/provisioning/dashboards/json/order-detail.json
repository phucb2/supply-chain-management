{
  "uid": "order-detail",
  "title": "Order Detail",
  "tags": ["supply-chain", "orders", "drill-down"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "order_id",
        "type": "textbox",
        "label": "Order ID",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Order $order_id",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Order Event Timeline",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"api|stream-processor\"} | json | order_id=\"$order_id\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Ascending",
        "enableLogDetails": true,
        "showLabels": true
      }
    },
    {
      "type": "traces",
      "title": "Order Traces",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "value": ["api", "stream-processor"],
              "scope": "resource"
            },
            {
              "id": "order-id",
              "tag": "order.id",
              "operator": "=",
              "value": ["$order_id"],
              "scope": "span"
            }
          ],
          "limit": 20,
          "refId": "A"
        }
      ]
    }
  ]
}
